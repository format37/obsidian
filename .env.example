# Obsidian LiveSync — environment configuration
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# ---- Always required ---------------------------------------------------------

# CouchDB admin username. Avoid "admin".
COUCHDB_USER=CHANGE_ME

# CouchDB admin password. Generate with: openssl rand -base64 32
COUCHDB_PASSWORD=CHANGE_ME

# Vault database name. The LiveSync plugin creates it on first sync.
COUCHDB_DATABASE=obsidian_vault

# Existing external Docker network the CouchDB container joins. Your reverse
# proxy MUST also be attached to this network so it can reach the container
# by the stable name `obsidian-couchdb` on port 5984.
EXTERNAL_NETWORK=CHANGE_ME

# ---- Bundled-Caddy mode only -------------------------------------------------
# Uncomment and fill these only when bringing up the Caddy overlay.

# Public hostname clients connect to. An A record for this name must point at
# this host before first start (Let's Encrypt HTTP-01 requirement).
# DOMAIN=your.domain.tld

# Email Let's Encrypt uses for expiry notifications.
# ACME_EMAIL=you@example.com
